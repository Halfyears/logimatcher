# ─── Supabase (free tier at supabase.com) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ─── Resend Email (free tier: 3000 emails/mo at resend.com) ─────────────────
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@logimatcher.com

# ─── Anthropic Claude API (for AI advisor chat) ──────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_API_KEY

# ─── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change_this_to_a_strong_password
ADMIN_SECRET=change_this_to_random_32_char_string

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Vercel Cron (survey auto-send) ──────────────────────────────────────────
CRON_SECRET=change_this_to_a_random_32_char_string
